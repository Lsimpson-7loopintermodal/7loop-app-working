{
  "name": "7loop-command-center",
  "version": "1.0.0",
  "private": true,
  "main": "electron.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && electron .\"",
    "package": "npm run build && electron-packager . \"7Loop Command Center\" --platform=win32,linux,darwin --arch=x64,ia32,arm64 --out=dist --overwrite",
    "package:win": "npm run build && electron-packager . \"7Loop Command Center\" --platform=win32 --arch=x64,ia32 --out=dist --overwrite",
    "package:mac": "npm run build && electron-packager . \"7Loop Command Center\" --platform=darwin --arch=x64,arm64 --out=dist --overwrite",
    "package:linux": "npm run build && electron-packager . \"7Loop Command Center\" --platform=linux --arch=x64,ia32,arm64 --out=dist --overwrite",
    "build:all": "npm run build && electron-packager . \"7Loop Command Center\" --platform=win32,linux,darwin --arch=x64,ia32,arm64 --out=dist --overwrite",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.7loop.commandcenter",
    "productName": "7Loop Command Center",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "7Loop Command Center",
      "include": "installer.nsh",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "7Loop-Command-Center-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
